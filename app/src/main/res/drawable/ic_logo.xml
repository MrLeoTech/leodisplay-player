<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Retângulo do Símbolo principal -->
    <path
        android:pathData="M150,150 L362,150 A30,30 0 0 1 392,180 L392,332 A30,30 0 0 1 362,362 L150,362 A30,30 0 0 1 120,332 L120,180 A30,30 0 0 1 150,150"
        android:strokeWidth="12"
        android:strokeColor="#2563EB" />

    <!-- Triângulo Play central com Gradiente Azul -->
    <path
        android:pathData="M230,210 L310,256 L230,302 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="230"
                android:startY="210"
                android:endX="310"
                android:endY="302"
                android:type="linear">
                <item android:color="#60A5FA" android:offset="0.0" />
                <item android:color="#2563EB" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Pixéis decorativos característicos -->
    <path android:fillColor="#60A5FA" android:pathData="M80,220 h20 v20 h-20z" />
    <path android:fillColor="#3B82F6" android:pathData="M105,250 h25 v25 h-25z" />
    <path android:fillColor="#2563EB" android:pathData="M75,280 h15 v15 h-15z" />
    <path android:fillColor="#1D4ED8" android:pathData="M110,200 h12 v12 h-12z" />

    <!-- Texto principal "LeoDisplay" (Vetorizado para consistência) -->
    <!-- Nota: No Android, é melhor usar TextView, mas para ícones/splash usamos paths -->
    <group android:translateX="80" android:translateY="420" android:scaleX="1.2" android:scaleY="1.2">
         <!-- Simulação do texto estilizado via Path se necessário,
              mas como temos TextView na Splash, focamos no símbolo aqui -->
    </group>
</vector>
